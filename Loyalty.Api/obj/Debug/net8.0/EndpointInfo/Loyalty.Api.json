{
  "openapi": "3.0.4",
  "info": {
    "title": "Loyalty.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/loyalty/calculate": {
      "post": {
        "tags": [
          "Loyalty"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateScoreRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateScoreRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateScoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CalculateScoreRequest": {
        "type": "object",
        "properties": {
          "purchaseAmount": {
            "type": "number",
            "format": "double"
          },
          "customerType": {
            "$ref": "#/components/schemas/CustomerType"
          },
          "monthlyPurchases": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CustomerType": {
        "enum": [
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  }
}